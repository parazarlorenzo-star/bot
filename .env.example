# Token de ton bot Telegram (obtenu via @BotFather)
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ton ID Telegram (pour l'accès admin)
# Trouve ton ID via @userinfobot sur Telegram
ADMIN_IDS=123456789

# Ton adresse wallet TON pour recevoir les dépôts
TON_WALLET=UQBxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ton adresse wallet USDT TRC20 pour recevoir les dépôts
USDT_WALLET=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
